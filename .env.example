# Telegram bot tokens — one per agent. Create via @BotFather, /setprivacy DISABLE for each.
TELEGRAM_BOT_TOKEN_MANAGER=
TELEGRAM_BOT_TOKEN_INTELLIGENCE=

# Comma-separated allow-lists. Without these set, the orchestrator refuses to start.
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_ALLOWED_USER_IDS=

# Anthropic key is validated at startup but NOT called anywhere in the skeleton.
ANTHROPIC_API_KEY=

# Storage + logging
STORE_PATH=data/store.db
LOG_LEVEL=INFO
