# Telegram bot tokens — one per agent. Create via @BotFather, /setprivacy DISABLE for each.
TELEGRAM_BOT_TOKEN_MANAGER=
TELEGRAM_BOT_TOKEN_INTELLIGENCE=
TELEGRAM_BOT_TOKEN_SECRETARY=

# Comma-separated allow-lists. Without these set, the orchestrator refuses to start.
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_ALLOWED_USER_IDS=

# Anthropic key. Required; validated at startup. Secretary (sub-project 6a) makes
# real calls through this key.
ANTHROPIC_API_KEY=

# LLM provider selection. Default: anthropic. "fake" uses FakeProvider (tests only).
LLM_PROVIDER=anthropic

# LLM model id. Default: claude-sonnet-4-6.
LLM_MODEL=claude-sonnet-4-6

# Storage + logging
STORE_PATH=data/store.db
LOG_LEVEL=INFO

# Google Calendar (sub-project 6b)
# Required for scripts/calendar_smoke.py and for Manager in 6c.
# USER_TIMEZONE must be a valid IANA zoneinfo name.
USER_TIMEZONE=Asia/Shanghai

# Which Google Calendar to read and write. Default "primary" is your
# default calendar. Change only if you keep real appointments elsewhere.
GOOGLE_CALENDAR_ID=primary

# Place your OAuth client secrets JSON at data/google_client_secrets.json.
# See README "Google Cloud setup" for the one-time steps to create it.
